# You do not need a .env file for local development: compose.yaml already includes safe defaults.
# Copy this file only when you need to change ports, local credentials, CORS origins, queue names, or shared service-token settings.

LARAVEL_PORT=8000
REALTIME_PORT=3000
ANALYTICS_API_PORT=8001
FRONTEND_PORT=5173
MAILPIT_PORT=8025
MYSQL_HOST_PORT=3307
ANALYTICS_POSTGRES_HOST_PORT=5433

APP_NAME=MaintOps
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
APP_URL=http://localhost:8000
API_VERSION=1.0.0
FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/reset-password
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

MYSQL_DATABASE=maintops
MYSQL_USER=maintops
MYSQL_PASSWORD=maintops-local-password
MYSQL_ROOT_PASSWORD=maintops-local-root-password

QUEUE_DEFAULT=default
QUEUE_EVENTS=events
QUEUE_MAIL=mail

MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=MaintOps

ANALYTICS_POSTGRES_DB=maintops_analytics
ANALYTICS_POSTGRES_USER=maintops_analytics
ANALYTICS_POSTGRES_PASSWORD=maintops-analytics-password

FRONTEND_ALLOWED_HOSTS=localhost,127.0.0.1
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_REALTIME_URL=http://localhost:3000
VITE_ANALYTICS_BASE_URL=http://localhost:8001

REALTIME_NODE_ENV=development
REALTIME_LOG_LEVEL=info
REALTIME_CORS_ORIGIN=http://localhost:5173
ANALYTICS_CORS_ORIGINS=["http://localhost:5173"]
SERVICE_TOKEN_SECRET=maintops-local-development-service-token-secret
OPERATIONS_ANALYTICS_SERVICE_KEY=maintops-local-development-analytics-service-key
REALTIME_ALLOWED_ROLES=super_admin,admin,workshop_manager,advisor,technician

MAINTOPS_EVENTS_STREAM=maintops:events
MAINTOPS_EVENTS_CONSUMER_GROUP=realtime-gateway
MAINTOPS_EVENTS_DEAD_LETTER_STREAM=maintops:events:dead-letter

ANALYTICS_INITIAL_SYNC_PAGE_SIZE=100
ANALYTICS_INITIAL_SYNC_TIMEOUT_SECONDS=15
ANALYTICS_REDIS_CONSUMER_GROUP=maintops-analytics-fastapi
ANALYTICS_REDIS_CONSUMER_NAME=analytics-worker
ANALYTICS_REDIS_BATCH_SIZE=50
ANALYTICS_REDIS_BLOCK_MS=5000
ANALYTICS_REDIS_PENDING_IDLE_MS=60000
ANALYTICS_DEFAULT_PERIOD_DAYS=30
ANALYTICS_MINIMUM_SAMPLE_SIZE=3
FORECAST_DEFAULT_HORIZON_DAYS=14
FORECAST_HISTORY_DAYS=28
FORECAST_MINIMUM_HISTORY_ACTIVITIES=5
