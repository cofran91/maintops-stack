# You do not need a .env file for local development: compose.yaml already includes safe defaults.
# Copy this file only when you need to change ports, local credentials, CORS origins, or shared realtime settings.

LARAVEL_PORT=8000
REALTIME_PORT=3000
FRONTEND_PORT=5173
MAILPIT_PORT=8025
MYSQL_HOST_PORT=3307

MYSQL_DATABASE=maintops
MYSQL_USER=maintops
MYSQL_PASSWORD=maintops-local-password
MYSQL_ROOT_PASSWORD=maintops-local-root-password

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_REALTIME_URL=http://localhost:3000

REALTIME_CORS_ORIGIN=http://localhost:5173
REALTIME_TOKEN_SECRET=maintops-local-development-realtime-token-secret
REALTIME_ALLOWED_ROLES=super_admin,admin,workshop_manager,advisor,technician

MAINTOPS_EVENTS_STREAM=maintops:events
MAINTOPS_EVENTS_CONSUMER_GROUP=realtime-gateway
MAINTOPS_EVENTS_DEAD_LETTER_STREAM=maintops:events:dead-letter
